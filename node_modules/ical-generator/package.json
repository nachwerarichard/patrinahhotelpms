    "name": "ical-generator",
    "peerDependencies": {
        "@touch4it/ical-timezones": ">=1.6.0",
        "@types/luxon": ">= 1.26.0",
        "@types/mocha": ">= 8.2.1",
        "dayjs": ">= 1.10.0",
